      "text": "Akıl yaşta değil, baştadır.",
      "category": "daily",
      "source": "Atasözü"
    },
    {
      "type": "soz",
      "text": "Dil, kalbin tercümanıdır.",
      "category": "daily",
      "source": "Mevlânâ"
    },
    {
      "type": "soz",
      "text": "İnsanı insan yapan bilgi değil, ahlâktır.",
      "category": "daily",
      "source": "Hacı Bektaş Veli"
    },
    {
      "type": "biyografik",
      "text": "Hayatım boyunca başarısız oldum, defalarca. İşte bu yüzden başardım.",
      "category": "daily",
      "source": "Michael Jordan"
    },
    {
      "type": "biyografik",
      "text": "Zeki insanlar fikir değiştirenlere denir; aptallar ise hiç değiştirmeyenlere.",
      "category": "daily",
      "source": "Bertrand Russell"
    },
    {
      "type": "tasavvufi",
      "text": "Nefsini bilen Rabbini bilir.",
      "category": "daily",
      "source": "Hadis-i Şerif (meşhur rivayet)"
    },
    {
      "type": "tasavvufi",
      "text": "Aşk olmayınca meşk olmaz.",
      "category": "daily",
      "source": "Mevlânâ"
    },
    {
      "type": "hukuki",
      "text": "Kanun önünde herkes eşittir.",
      "category": "daily",
      "source": "Evrensel İnsan Hakları Beyannamesi, Madde 7"
    },
    {
      "type": "hukuki",
      "text": "Suçlu olduğu kanıtlanana kadar herkes masumdur.",
      "category": "daily",
      "source": "Masumiyet Karinesi — Roma Hukuku"
    },
    {
      "type": "mitolojik",
      "text": "Kibir, tanrıların en çok nefret ettiği günahtır.",
      "category": "daily",
      "source": "Antik Yunan — Hubris kavramı"
    },
    {
      "type": "mitolojik",
      "text": "Prometeus ateşi çaldı; insanlığa verdi. Tanrılar onu zincirledi ama ateş söndürülemedi.",
      "category": "daily",
      "source": "Yunan Mitolojisi — Hesiodos"
    }
    ]
